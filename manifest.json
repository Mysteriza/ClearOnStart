{
  "manifest_version": 3,
  "name": "ClearOnStart",
  "short_name": "ClearOnStart",
  "version": "1.1.4",
  "description": "Wipe browsing history, cached images, download records, and autofill form data the moment Chrome opens.",
  "minimum_chrome_version": "108",
  "permissions": [
    "browsingData",
    "storage",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ClearOnStart",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
